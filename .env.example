# === BDR OS — Connection Registry ===
# Copy to .env and fill in values. registry.py resolves adapters from these.

# Database
DATABASE_URL=sqlite:///./bdr_os.db

# Adapter selection (mock | real implementation name)
ADAPTER_CRM=mock
ADAPTER_EMAIL=mock
ADAPTER_CALENDAR=mock
ADAPTER_ENRICHMENT=mock
ADAPTER_CALLRECORDING=mock

# Real adapter credentials (fill when connecting)
# ANTHROPIC_API_KEY=...
# GMAIL_CREDENTIALS_JSON=...
# GCAL_CREDENTIALS_JSON=...

# Policy
DRAFT_ONLY_UNTIL=2026-09-15
MAX_NEW_OUTBOUND_PER_DAY=40
MAX_TOUCHES_PER_CONTACT_PER_WEEK=3
STRATEGIC_ACCOUNTS=[]

# Cold start
COLD_START=true
